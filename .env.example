# ============================================
# 生产环境变量配置
# ============================================
# 复制此文件为 .env 并填写实际值:
#   cp .env.example .env
# ============================================

# ---------- 数据库 ----------
# 数据库密码（请修改为强密码）
DB_PASSWORD=change_me_to_strong_password

# ---------- AI API ----------
# OpenAI 或兼容 API 的 Key
OPENAI_API_KEY=sk-your-key-here

# 自定义 Base URL（可选）
# 留空则使用 OpenAI 官方
# DeepSeek: https://api.deepseek.com/v1
# 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=

# 模型名称（可选，默认 gpt-4o）
AI_MODEL=gpt-4o

# AI 显示名称（可选，默认 AI）
AI_NAME=AI

# ---------- 应用 ----------
# 你的域名（用于 Nginx 配置）
DOMAIN=040869.xyz
